# URL to redirect users outside Telegram (leave empty for local dev / browser access)
VITE_REDIRECT_URL=

# Telegram Bot Token (used by bot webhook + Telegram sign-in)
# Get from @BotFather: https://t.me/BotFather
BOT_TOKEN=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for server-side user management)
# Get from Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# AI Provider Configuration
# Set to 'openrouter' or 'openai'
VITE_AI_PROVIDER=openrouter

# OpenRouter API Key (only needed with VITE_AI_PROVIDER=openrouter)
VITE_OPENROUTER_API_KEY=

# OpenAI API Key (only needed with VITE_AI_PROVIDER=openai)
# VITE_OPENAI_API_KEY=

# AI Model to use (free: nvidia/nemotron-3-nano-30b-a3b:free)
VITE_AI_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# Paystack
# Get your public key from https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
# Get your secret key from the same page (server-side only, never exposed to client)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Download Bridge URL
# Deploy n8n-dataset-downloader to Vercel and put the URL here
VITE_DOWNLOADER_URL=https://nene2u.vercel.app
