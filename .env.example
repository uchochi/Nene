# Telegram Mini App Configuration
# Set the URL users are redirected to outside Telegram (leave empty for local dev)
VITE_REDIRECT_URL=

# Telegram Bot Token (used by middleware HMAC verification + bot webhook)
# Get from @BotFather: https://t.me/BotFather
BOT_TOKEN=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for server-side user management)
# Get from Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT Secret (for signing custom Telegram auth JWTs)
# Get from Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# AI Provider Configuration
# Set to 'openrouter' or 'openai'
VITE_AI_PROVIDER=openrouter

# OpenRouter API Key (only needed with VITE_AI_PROVIDER=openrouter)
VITE_OPENROUTER_API_KEY=

# OpenAI API Key (only needed with VITE_AI_PROVIDER=openai)
# VITE_OPENAI_API_KEY=

# AI Model to use (e.g. gpt-4o-mini, gpt-4o, claude-3-haiku, claude-3-sonnet)
VITE_AI_MODEL=gpt-4o-mini
